# Picked up by `next build` / Vercel (no need to set in dashboard unless you want to override).
# Leave empty when the portal is served from the same host under /portal (path-based deploy).
NEXT_PUBLIC_PORTAL_URL=

# If the portal is a separate site, set its origin (no trailing slash), e.g.:
# NEXT_PUBLIC_PORTAL_URL=https://your-portal.vercel.app
