{
  "name": "najurist",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "dev:with-portal": "concurrently -n SITE,PORTAL -c blue,magenta \"next dev --webpack\" \"npm --prefix law-firm-portal/frontend run dev\"",
    "dev:mono": "concurrently -k -n WEB,PORTAL,API,PROXY -c blue,magenta,green,cyan \"cross-env NEXT_PUBLIC_PORTAL_URL=http://localhost:3000/portal next dev --webpack --port 3001\" \"npm --prefix law-firm-portal/frontend run dev:mono\" \"cross-env FRONTEND_ORIGIN=http://localhost:3000,http://localhost:5173 npm --prefix law-firm-portal/backend run dev\" \"node scripts/mono-proxy.mjs\"",
    "build:portal": "node scripts/run-portal-build.mjs",
    "build": "npm run build:portal && next build --webpack",
    "start": "next start",
    "lint": "next lint",
    "extract-judgments": "node scripts/extract-judgments.js",
    "import:civil-cases": "node scripts/import-civil-court-cases.mjs"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@hookform/resolvers": "^5.0.1",
    "@supabase/supabase-js": "^2.89.0",
    "@types/nodemailer": "^6.4.17",
    "cheerio": "^1.1.0",
    "cloudinary": "^2.8.0",
    "framer-motion": "^12.23.22",
    "lucide-react": "^0.487.0",
    "mammoth": "^1.9.1",
    "next": "^16.1.0",
    "nodemailer": "^6.10.1",
    "pdf-parse": "^2.1.7",
    "pdfkit": "^0.18.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-hook-form": "^7.55.0",
    "react-icons": "^5.5.0",
    "uuid": "^11.1.0",
    "xlsx": "^0.18.5",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pdfkit": "^0.17.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "dotenv": "^17.2.3",
    "form-data": "^4.0.5",
    "http-proxy": "^1.18.1",
    "postcss": "^8.5.6",
    "postcss-custom-properties": "^14.0.6",
    "tailwindcss": "^4.1.11",
    "typescript": "^5"
  }
}
