# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# Embedded Vite portal (generated by `npm run build:portal`)
/public/portal/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example
!.env.production

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# law-firm-portal workspaces
law-firm-portal/**/node_modules
law-firm-portal/**/dist
law-firm-portal/**/.env
law-firm-portal/**/.env.local
law-firm-portal/scripts/seed-admin.env

# Supabase CLI / mistaken nested init
law-firm-portal/supabase/.temp/
law-firm-portal/frontend/supabase/
