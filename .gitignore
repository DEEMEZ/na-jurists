# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# Embedded Vite portal (generated by `npm run build:portal`)
/public/portal/

# production
/build

# misc
.DS_Store
Thumbs.db
*.pem
*.log

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env / secrets (never commit; copy from .env.example)
.env
.env.*
!.env.example
law-firm-portal/**/.env
law-firm-portal/**/.env.*
!law-firm-portal/**/.env.example
!law-firm-portal/scripts/seed-admin.env.example
law-firm-portal/scripts/seed-admin.env

# vercel / IDE / agent
.vercel
.cursor/
.vscode/
.idea/

# typescript
*.tsbuildinfo
next-env.d.ts

# law-firm-portal workspaces
law-firm-portal/**/node_modules
law-firm-portal/**/dist
law-firm-portal/backend/prisma/*.db
law-firm-portal/backend/prisma/*.db-journal

# Supabase CLI temp
/supabase/.temp/
law-firm-portal/supabase/.temp/
law-firm-portal/frontend/supabase/

# --- Large local-only source assets (site uses committed copies under public/) ---
# Original client Word/PDF sources; website serves public/reported-judgement-pdfs/*.pdf
Reported Judgements/
Reported Judgements PDF/

# Word source lists (imported into public/data/cases.json — keep JSON in git)
/Civil Courts cases list.docx
/public/data/*.docx

# Regenerated by scripts/import-civil-court-cases.mjs
/scripts/data/

# Script output / upload logs
scripts/cloudinary-upload-results.json

# Internal notes (keep root README.md only)
PERFORMANCE_AUDIT.md
scripts/README.md
law-firm-portal/frontend/README.md
law-firm-portal/DEPLOYMENT.md
law-firm-portal/SUPABASE.md
