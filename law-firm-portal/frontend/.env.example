# Local dev: copy to .env.local
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Optional — URL of `npm run dev` for the main Next app (Vite proxies /api here). Default http://127.0.0.1:3000.
# Use http://127.0.0.1:3001 when Next prints “Port 3000 is in use, using 3001”.
# VITE_NEXT_DEV_ORIGIN=http://127.0.0.1:3001

# Optional – portal “Reported judgments” → Load from website API (must allow CORS from portal origin)
# Dev: defaults to http://localhost:3000 if unset (same machine Next dev).
# VITE_PUBLIC_WEBSITE_ORIGIN=http://localhost:3001
# VITE_PUBLIC_WEBSITE_ORIGIN=https://your-production-site.example
# Alias (either works):
# VITE_WEBSITE_URL=https://your-production-site.example
